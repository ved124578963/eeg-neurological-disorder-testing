<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="NeuroDetect Frontend Test Suite" verbose="1">

    <!-- Global parameters available to all tests -->
    <parameter name="baseUrl"   value="http://localhost:5173"/>
    <parameter name="browser"   value="chrome"/>
    <parameter name="headless"  value="false"/>

    <test name="Navigation Tests">
        <classes>
            <class name="com.neurodetect.tests.NavigationTest"/>
        </classes>
    </test>

    <test name="Dashboard Tests">
        <classes>
            <class name="com.neurodetect.tests.DashboardTest"/>
        </classes>
    </test>

    <test name="About Page Tests">
        <classes>
            <class name="com.neurodetect.tests.AboutPageTest"/>
        </classes>
    </test>

    <test name="Input Page Tests">
        <classes>
            <class name="com.neurodetect.tests.InputPageTest"/>
        </classes>
    </test>

    <test name="Supported Disorders Tests">
        <classes>
            <class name="com.neurodetect.tests.SupportedDisordersTest"/>
        </classes>
    </test>

    <test name="Team Page Tests">
        <classes>
            <class name="com.neurodetect.tests.TeamPageTest"/>
        </classes>
    </test>

    <test name="Contact Page Tests">
        <classes>
            <class name="com.neurodetect.tests.ContactPageTest"/>
        </classes>
    </test>

</suite>
